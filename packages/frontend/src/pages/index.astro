<style is:global>
  .how-img {
    opacity: 0;
    transform: translateY(10px) scale(0.985);
    transition: opacity 240ms ease, transform 240ms ease;
    will-change: opacity, transform;
    pointer-events: none;
    filter: drop-shadow(0 20px 30px rgba(0,0,0,.15));
  }
  .how-img.is-active {
    opacity: 1;
    transform: translateY(0) scale(1);
  }

  @media (prefers-reduced-motion: reduce) {
    .how-img { transition: none; transform: none; }
  }
</style>


<script>
  const cards = Array.from(document.querySelectorAll("[data-step-card]"));
  const imgs = Array.from(document.querySelectorAll("[data-step-img]"));

  function setActive(step: string): void {
    imgs.forEach((img) => {
      img.classList.toggle("is-active", img.getAttribute("data-step-img") === step);
    });

    cards.forEach((c) => {
      c.classList.toggle("is-active", c.getAttribute("data-step-card") === step);
    });
  }

  setActive("1");

  cards.forEach((card) => {
    const step = card.getAttribute("data-step-card");
    
    if (!step) return; 

    card.addEventListener("mouseenter", () => setActive(step));
    card.addEventListener("focus", () => setActive(step));

    card.addEventListener("click", () => setActive(step));
  });

  const container = document.querySelector("#como-funciona");
  container?.addEventListener("mouseleave", () => setActive("1"));
</script>