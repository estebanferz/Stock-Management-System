---
import LayoutLanding from '@/layouts/LayoutLanding.astro';
import { requireAuth } from '@/lib/requireAuth';
import { HammerIcon, HeadphonesIcon, MinusCircle, PlusCircle, ShoppingBagIcon, SmartphoneIcon } from 'lucide-react';

const APP_NAME = "Zuma+";
const CTA_PRIMARY = "Probar gratis";
const CTA_SECONDARY = "Ver precios";
const WHATSAPP_URL = "https://wa.me/5492234370460?text=Hola%20Zuma%2B%2C%20quiero%20saber%20más%20sobre%20el%20producto%20y%20los%20precios.";
const SUPPORT_EMAIL = "support@zumaplus.com.ar";

const session = await requireAuth(Astro);
if (session) return Astro.redirect("/dashboard");
---

<LayoutLanding title={APP_NAME}>
  <!-- Header -->
  <header class="sticky top-0 z-50 border-b border-zinc-200/70 bg-white/80 backdrop-blur">
    <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-3">
      <a href="#top" class="flex items-center gap-2 font-semibold tracking-tight">
        <span class="inline-flex h-9 w-9 items-center justify-center rounded-xl">
          <img src="/zuma-logo.png" alt={`${APP_NAME} logo`} />
        </span>
        <span class="text-lg">{APP_NAME}</span>
      </a>

      <nav class="hidden items-center gap-6 text-sm text-zinc-700 md:flex">
        <a class="hover:text-zinc-950" href="#producto">Producto</a>
        <a class="hover:text-zinc-950" href="#casos-de-uso">Casos de uso</a>
        <a class="hover:text-zinc-950" href="#como-funciona">Cómo funciona</a>
        <a class="hover:text-zinc-950" href="#precio">Precio</a>
        <a class="hover:text-zinc-950" href="#faq">FAQ</a>
        <a class="hover:text-zinc-950" href="#contacto">Contacto</a>
      </nav>

      <div class="flex items-center gap-2">
        <a
          href="/dashboard"
          class="rounded-xl px-4 py-2 text-sm font-medium text-zinc-800 hover:bg-zinc-100 inline-flex"
        >
          Ingresar
        </a>
        <a
          href="#precio"
          class="inline-flex items-center justify-center rounded-xl bg-gradient-to-bl from-mainColor to-fourthColor px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-gradient-to-tr hover:from-secondColor hover:to-thirdColor hover:scale-110 hover:shadow-lg transition-transform"
        >
          {CTA_PRIMARY}
        </a>
      </div>
    </div>
  </header>

  <main id="top">
    <!-- Hero -->
    <section class="mx-auto max-w-7xl px-4 pt-14 pb-10">
      <div class="grid items-center gap-10 md:grid-cols-2">
        <div>
          <div class="inline-flex items-center gap-2 rounded-full border border-zinc-200 bg-white px-3 py-1 text-xs text-zinc-700 shadow-sm">
            <span class="font-semibold">Prueba gratis</span>
            <span class="text-zinc-500">•</span>
            <span>Listo en 10 minutos</span>
            <span class="text-zinc-500">•</span>
            <span>Soporte humano</span>
          </div>

          <h1 class="mt-4 text-4xl font-black tracking-tight md:text-5xl">
            Ordená tu negocio y ganá control real.
          </h1>

          <p class="mt-4 text-base leading-relaxed text-zinc-700 md:text-lg">
            Ventas, stock, clientes, deudas y caja en un solo sistema. Menos Excel, menos errores y más decisiones con
            números claros.
          </p>

          <div class="mt-6 flex flex-col gap-3 sm:flex-row sm:items-center">
            <a
              href="#precio"
              class="inline-flex items-center justify-center rounded-xl bg-zinc-900 px-5 py-3 text-sm font-semibold text-white shadow-sm hover:bg-zinc-800"
            >
              {CTA_PRIMARY}
            </a>
            <a
              href="#precio"
              class="inline-flex items-center justify-center rounded-xl border border-zinc-200 bg-white px-5 py-3 text-sm font-semibold text-zinc-900 hover:bg-zinc-50"
            >
              {CTA_SECONDARY}
            </a>
          </div>

          <div class="mt-4 grid gap-2 text-sm text-zinc-600">
            <div class="flex items-center gap-2">
              <span class="inline-flex h-5 w-5 items-center justify-center rounded-full border border-zinc-200 bg-white text-[10px] font-black text-zinc-900">✓</span>
              <span>Sin tarjeta para empezar</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="inline-flex h-5 w-5 items-center justify-center rounded-full border border-zinc-200 bg-white text-[10px] font-black text-zinc-900">✓</span>
              <span>Funciona desde celular y computadora</span>
            </div>
            <div class="flex items-center gap-2">
              <span class="inline-flex h-5 w-5 items-center justify-center rounded-full border border-zinc-200 bg-white text-[10px] font-black text-zinc-900">✓</span>
              <span>Cancelás cuando quieras</span>
            </div>
          </div>

          <!-- <div class="mt-6 flex items-center gap-3 text-sm text-zinc-600">
            <div class="flex -space-x-2">
              {["MR", "CG", "LS", "JP", "AR"].map((x) => (
                <div class="flex h-9 w-9 items-center justify-center rounded-full border border-white bg-zinc-900 text-xs font-bold text-white shadow-sm">
                  {x}
                </div>
              ))}
            </div>
            <span>
              <span class="font-semibold text-zinc-900">Hecho para</span> negocios que venden y cobran todos los días
            </span>
          </div> -->
        </div>

        <!-- Mockup -->
        <div class="relative">
          <div class="rounded-3xl border border-zinc-200 bg-white p-4 shadow-lg shadow-secondColor/40">
            <div class="flex items-center justify-between">
              <div class="flex items-center gap-2">
                <div class="h-4 w-4 rounded-full bg-[#ff383c]"></div>
                <div class="h-4 w-4 rounded-full bg-[#ffcc01]"></div>
                <div class="h-4 w-4 rounded-full bg-[#34c759]"></div>
              </div>
              <div class="text-xs text-zinc-500">zuma.app/dashboard</div>
            </div>

            <div class="mt-5 grid gap-3 grid-cols-2">
              <div class="rounded-2xl border border-zinc-200 bg-zinc-50 p-4 hover:scale-105 hover:shadow-lg transition-transform">
                <div class="text-xs text-zinc-500">Inversión en Stock</div>
                <div class="mt-2 text-2xl font-black">US$ 14.580</div>
                <div class="mt-2 inline-flex items-center gap-2 rounded-full bg-white px-2 py-1 text-xs text-zinc-700 ring-1 ring-zinc-200">
                  <span class="h-2 w-2 rounded-full bg-emerald-500"></span>
                  Actualizado
                </div>
              </div>

              <div class="rounded-2xl border border-zinc-200 bg-white p-4 hover:scale-105 hover:shadow-lg transition-transform">
                <div class="text-xs text-zinc-500">Ingresos netos</div>
                <div class="mt-2 text-2xl font-black">US$ 8.450</div>
                <div class="mt-2 text-xs text-zinc-600">Resumen automático</div>
              </div>

              <div class="rounded-2xl border border-zinc-200 bg-white p-4 hover:scale-105 hover:shadow-lg transition-transform">
                <div class="text-xs text-zinc-500">Unidades vendidas</div>
                <div class="mt-2 text-2xl font-black">48</div>
                <div class="mt-2 text-xs text-zinc-600">Último mes</div>
              </div>

              <div class="rounded-2xl border border-zinc-200 bg-white p-4 hover:scale-105 hover:shadow-lg transition-transform">
                <div class="text-xs text-zinc-500">Cobros por deuda</div>
                <div class="mt-2 text-2xl font-black">12</div>
                <div class="mt-2 text-xs text-zinc-600">Cobros pendientes</div>
              </div>
            </div>
          </div>

          <div class="pointer-events-none absolute -inset-6 -z-10 rounded-[2.5rem] bg-zinc-900/5 blur-2xl"></div>
        </div>
      </div>
    </section>

    <!-- Problema -> Solución -->
    <section class="grid grid-cols-1 lg:grid-cols-3 mx-auto max-w-[1600px] px-4 py-12" id="producto">
      <div class="col-span-1 rounded-3xl lg:pl-10">
        <div class="flex flex-col gap-2">
          <div class="text-sm font-semibold text-[#363638]">Lo que cambia con {APP_NAME}</div>
          <h2 class="text-4xl text-[#242426] font-black tracking-tight">
            Si hoy gestionás con Excel…<br/> 
          </h2>
          <h2 class="text-4xl max-w-fit font-black tracking-tight text-white pl-2 pr-4  bg-[#ff383c]">estás perdiendo control.</h2>
          <p class="mt-3 text-zinc-700">
            El día a día te come y la info queda desordenada. {APP_NAME} ordena el flujo completo para que sepas qué
            vendiste, qué te deben, cuánto ganaste y qué falta reponer.
          </p>
        </div>
        
        <div class="grid mt-6 gap-4 md:grid-cols-2">
          <div class="rounded-2xl border border-zinc-200 bg-zinc-50 p-5 hover:scale-105 hover:shadow-lg hover:shadow-[#ff383c]/20 transition-transform">
            <h3 class="font-extrabold text-xl">Antes</h3>
            <ul class="mt-3 space-y-2 text-sm text-zinc-700">
              <li><MinusCircle height={16} width={16} className="inline mr-1 text-[#ff383c]" /> Ventas anotadas en distintos lados</li>
              <li><MinusCircle height={16} width={16} className="inline mr-1 text-[#ff383c]" /> Stock “aproximado” y sorpresas</li>
              <li><MinusCircle height={16} width={16} className="inline mr-1 text-[#ff383c]" /> Deudas sin seguimiento real</li>
              <li><MinusCircle height={16} width={16} className="inline mr-1 text-[#ff383c]" /> Caja que no cierra</li>
              <li><MinusCircle height={16} width={16} className="inline mr-1 text-[#ff383c]" /> Buscar info te lleva minutos</li>
            </ul>
          </div>
          
          <div class="rounded-2xl bg-gradient-to-tr from-mainColor to-fourthColor p-[4px] shadow-2xl shadow-secondColor/40 hover:scale-105 transition-transform">
            <div class="rounded-xl group border border-zinc-200 bg-white p-5 hover:bg-gradient-to-tr hover:from-mainColor hover:to-fourthColor hover:text-white transition-colors duration-200 hover:border-0">
              <h3 class="font-extrabold text-xl">{APP_NAME}</h3>
              <ul class="mt-3 space-y-2 text-sm text-zinc-700 group-hover:text-white transition-colors duration-300">
                <li><PlusCircle height={16} width={16} className="inline mr-1 text-[#34c759] group-hover:text-white" /> Cada venta deja todo actualizado</li>
                <li><PlusCircle height={16} width={16} className="inline mr-1 text-[#34c759] group-hover:text-white" /> Stock en tiempo real + alertas</li>
                <li><PlusCircle height={16} width={16} className="inline mr-1 text-[#34c759] group-hover:text-white" /> Deudas con vencimientos y parciales</li>
                <li><PlusCircle height={16} width={16} className="inline mr-1 text-[#34c759] group-hover:text-white" /> Caja clara por método de pago</li>
                <li><PlusCircle height={16} width={16} className="inline mr-1 text-[#34c759] group-hover:text-white" /> Encontrás todo en segundos</li>
              </ul>
            </div>
          </div>
        </div>
      </div>

      <img src="/macbook-inventory-landing.png" class="col-span-2 pt-8 lg:p-8 lg:pr-0 mt-3 lg:mt-0">
    </section>

    <!-- Casos de uso -->
    <section class="mx-auto max-w-6xl px-4 py-12" id="casos-de-uso">
      <div class="text-center">
        <div class="text-md font-semibold text-[#363638]">Casos de uso</div>
        <h2 class="mt-2 text-4xl font-black tracking-tight text-[#242426]">
          Hecho para negocios que <span class="text-5xl bg-gradient-to-r from-mainColor to-fourthColor
           bg-clip-text text-transparent">venden</span> y <span class="text-5xl bg-gradient-to-r from-mainColor to-fourthColor
           bg-clip-text text-transparent">cobran</span> todos los días
        </h2>
        <p class="mt-3 text-lg text-zinc-700">
          Elegí tu caso y empezá con lo esencial. El resto se acomoda solo.
        </p>
      </div>

      <div class="mt-8 grid gap-6 grid-cols-2 md:grid-cols-4">
        {[
          {
            icon: SmartphoneIcon,
            title: "Tienda de celulares",
            desc: "Registrá ventas rápido y mantené stock bajo control.",
          },
          {
            icon: HammerIcon,
            title: "Servicio técnico",
            desc: "Organizá cobros, estados y pendientes sin perder seguimiento.",
          },
          {
            icon: ShoppingBagIcon,
            title: "Compra-venta",
            desc: "Controlá costos y resultados por operación con claridad.",
          },
          {
            icon: HeadphonesIcon,
            title: "Accesorios",
            desc: "Rotación, reposición y control real del inventario.",
          },
        ].map(({ icon: Icon, title, desc }) => (
          <div class="rounded-3xl p-6 hover:shadow-md transition-shadow">
            <Icon height={48} width={48} className="text-mainColor mb-4" />
            <div class="font-bold text-xl text-[#242426]">{title}</div>
            <p class="mt-2 text-md leading-relaxed text-[#363638]">{desc}</p>
          </div>
        ))}
      </div>
    </section>

    <!-- Cómo funciona -->
    <section class="mx-auto max-w-7xl py-12" id="como-funciona">
      <div class="rounded-3xl p-6 md:p-8">
        <div class="text-center mb-5">
          <div class="text-md font-semibold text-[#363638]">Simple y rápido</div>
          <h2 class="text-4xl font-black tracking-tight text-[#242426]">
            Empezá en <span class="text-6xl bg-gradient-to-r from-mainColor to-fourthColor
           bg-clip-text text-transparent">3</span> pasos
          </h2>
          <p class="mt-3 text-[#363638]">
            Sin vueltas. Si usás WhatsApp, podés usar {APP_NAME}.
          </p>
        </div>

        <div class="grid gap-8 lg:grid-cols-5 lg:items-center">

          <!-- PASOS -->
          <div class="order-1 lg:order-2 lg:col-span-3">
            <!-- sm/md: 3 columnas | lg: vertical -->
            <div class="grid grid-cols-1 md:grid-cols-3 gap-5 lg:flex lg:flex-col">
              {[
                ["1", "Creá tu cuenta", "En minutos. Sin tarjeta para empezar."],
                ["2", "Cargá lo básico", "Productos, clientes y precios."],
                ["3", "Operá y mirá tus números", "Vendés, cobrás y el sistema te deja todo listo para controlar."],
              ].map(([n, t, d]) => (
                <div
                  data-step-card={n}
                  tabindex="0"
                  class="rounded-3xl border border-zinc-200 bg-zinc-50 p-6 py-8
                        transform duration-200 hover:scale-105
                        shadow-lg shadow-secondColor/40
                        hover:border-0 hover:shadow-2xl
                        hover:bg-gradient-to-tr hover:from-mainColor hover:to-fourthColor hover:text-white
                        focus:scale-105 outline-none"
                >
                  <div class="text-3xl font-black">{n}</div>
                  <div class="text-lg mt-2 font-bold">{t}</div>
                  <div class="mt-2 text-sm font-light">{d}</div>
                </div>
              ))}
            </div>
          </div>

          <!-- IMÁGENES -->
          <div class="order-2 lg:order-1 lg:col-span-2">
            <div class="relative mx-auto h-[520px] sm:h-[600px] lg:h-[720px] w-full max-w-[360px]">
              <img
                data-step-img="1"
                src="/iphone-signup-landing.png"
                class="how-img absolute inset-0 mx-auto h-full w-auto"
                alt="Paso 1"
              />
              <img
                data-step-img="2"
                src="/iphone-addsale-landing.png"
                class="how-img absolute inset-0 mx-auto h-full w-auto"
                alt="Paso 2"
              />
              <img
                data-step-img="3"
                src="/iphone-dashboard-landing.png"
                class="how-img absolute inset-0 mx-auto h-full w-auto"
                alt="Paso 3"
              />
            </div>
          </div>

        </div>
      </div>
    </section>

    <!-- Funcionalidades -->
    <section class="mx-auto max-w-6xl px-4 py-12" id="caracteristicas">
      <div class="text-center">
        <div class="text-sm font-semibold text-zinc-900">Producto</div>
        <h2 class="mt-2 text-4xl font-black tracking-tight text-[#242426]">Confiabilidad que no falla</h2>
        <p class="mt-3 text-zinc-700">Menos carga manual. Más orden. Mejor decisión.</p>
      </div>

      <div class="mt-8 grid gap-4 md:grid-cols-3">
        {[
          ["Vendé y registrá en segundos", "Cada venta actualiza cliente, stock, deuda y caja automáticamente."],
          ["Stock que no te sorprende", "Inventario en tiempo real y alertas cuando toca reponer."],
          ["Clientes con historial y saldo", "Compras, contactos y cuentas pendientes en un solo lugar."],
          ["Caja clara por método", "Efectivo, transferencias y tarjetas separados, sin confusión."],
          ["Reportes simples para decidir", "Ventas, resultados y evolución mensual sin fórmulas."],
          ["Acceso desde cualquier dispositivo", "Tu negocio disponible desde celular o computadora."],
        ].map(([t, d]) => (
          <div class="rounded-3xl border border-zinc-200 bg-white p-6 shadow-sm hover:shadow-md transition-shadow">
            <div class="flex items-start gap-3">
              <div class="mt-1 inline-flex h-10 w-10 items-center justify-center rounded-2xl border border-zinc-200 bg-zinc-50 font-black">
                +
              </div>
              <div>
                <h3 class="font-bold">{t}</h3>
                <p class="mt-2 text-sm leading-relaxed text-zinc-700">{d}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </section>

    <!-- Seguridad -->
    <section class="mx-auto max-w-6xl px-4 py-12" id="seguridad">
      <div class="rounded-3xl border border-zinc-200 bg-white p-6 shadow-sm md:p-10">
        <div class="grid gap-8 md:grid-cols-2">
          <div>
            <div class="text-sm font-semibold text-zinc-900">Confianza</div>
            <h2 class="mt-2 text-3xl font-black tracking-tight">Tus datos, seguros y disponibles</h2>
            <p class="mt-3 text-zinc-700">
              Tu info no depende de una compu ni de un archivo suelto. Todo queda organizado y accesible cuando lo
              necesitás.
            </p>
          </div>

          <div class="grid gap-4 md:grid-cols-2">
            {[
              ["Backups automáticos", "Respaldo para evitar pérdidas."],
              ["Accesos por usuario", "Cada uno con su rol y permisos."],
              ["Datos en la nube", "Accedé desde donde estés."],
              ["Exportación", "Llevate tu info cuando lo necesites."],
            ].map(([t, d]) => (
              <div class="rounded-2xl border border-zinc-200 bg-zinc-50 p-5">
                <div class="font-bold">{t}</div>
                <div class="mt-1 text-sm text-zinc-700">{d}</div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </section>

    <!-- Testimonios -->
    <section class="mx-auto max-w-6xl px-4 py-12" id="testimonios">
      <div class="text-center">
        <div class="text-sm font-semibold text-zinc-900">Testimonios</div>
        <h2 class="mt-2 text-3xl font-black tracking-tight">Menos lío. Más control.</h2>
        <p class="mt-3 text-zinc-700">Negocios que dejaron Excel y ahora miran números claros.</p>
      </div>

      <div class="mt-8 grid gap-4 md:grid-cols-3">
        {[
          [
            "Antes tenía ventas por todos lados. Ahora cierro el día y sé exactamente cuánto entró y cuánto queda por cobrar.",
            "María Rodríguez",
            "Casa de Celulares",
            "MR",
          ],
          [
            "Lo mejor es el stock y el seguimiento de deudas. Dejé de reponer tarde y de perder tiempo buscando info.",
            "Carlos González",
            "TecnoStore",
            "CG",
          ],
          [
            "Es directo y fácil. En una tarde lo configuré y ya estaba registrando ventas. El soporte responde rápido.",
            "Laura Sánchez",
            "SmartPhone Plus",
            "LS",
          ],
        ].map(([quote, name, biz, initials]) => (
          <figure class="rounded-3xl border border-zinc-200 bg-white p-6 shadow-sm">
            <blockquote class="text-sm leading-relaxed text-zinc-700">“{quote}”</blockquote>
            <figcaption class="mt-4 flex items-center gap-3">
              <div class="flex h-10 w-10 items-center justify-center rounded-2xl bg-zinc-900 text-xs font-bold text-white">
                {initials}
              </div>
              <div>
                <div class="text-sm font-bold">{name}</div>
                <div class="text-xs text-zinc-600">{biz}</div>
              </div>
            </figcaption>
          </figure>
        ))}
      </div>
    </section>

    <!-- FAQ -->
    <section class="mx-auto max-w-6xl px-4 py-12" id="faq">
      <div class="rounded-3xl border border-zinc-200 bg-white p-6 shadow-sm md:p-10">
        <div class="text-center">
          <div class="text-sm font-semibold text-zinc-900">FAQ</div>
          <h2 class="mt-2 text-3xl font-black tracking-tight">Resolvemos tus dudas</h2>
          <p class="mt-3 text-zinc-700">Lo que normalmente preguntan antes de empezar.</p>
        </div>

        <div class="mt-8 grid gap-4 md:grid-cols-2">
          {[
            ["¿Puedo usarlo desde el celular?", `Sí. ${APP_NAME} funciona perfecto desde cualquier celular o computadora.`],
            ["¿Puedo llevar deudas y pagos parciales?", "Sí. Podés ver saldos, vencimientos y registrar pagos parciales."],
            ["¿Puedo exportar mis datos?", "Sí. Podés exportar la información cuando lo necesites."],
            ["¿Necesito tarjeta para la prueba?", "No. Podés empezar gratis sin tarjeta y decidir después."],
            ["¿Me ayudan a configurarlo?", "Sí. Si te trabás, te damos una mano para dejarlo listo."],
            ["¿Qué pasa si cancelo?", "Cancelás cuando quieras. Tus datos quedan disponibles según tu plan y política de exportación."],
          ].map(([q, a]) => (
            <details class="group rounded-2xl border border-zinc-200 bg-zinc-50 p-5">
              <summary class="cursor-pointer list-none font-bold text-zinc-900">
                <span class="select-none">{q}</span>
                <span class="float-right text-zinc-500 group-open:rotate-45 transition-transform">+</span>
              </summary>
              <p class="mt-3 text-sm text-zinc-700">{a}</p>
            </details>
          ))}
        </div>

        <div class="mt-8 flex flex-col items-center gap-3">
          <div class="text-sm text-zinc-700">¿Tenés una consulta puntual?</div>
          <a
            href={WHATSAPP_URL}
            class="inline-flex items-center justify-center rounded-xl border border-zinc-200 bg-white px-5 py-3 text-sm font-semibold text-zinc-900 hover:bg-zinc-50"
            target="_blank"
            rel="noreferrer"
          >
            Hablar por WhatsApp
          </a>
        </div>
      </div>
    </section>

    <!-- Precio -->
    <section class="mx-auto max-w-6xl px-4 py-12" id="precio">
      <div class="text-center">
        <div class="text-sm font-semibold text-zinc-900">Precio</div>
        <h2 class="mt-2 text-3xl font-black tracking-tight">Un precio. Todo incluido.</h2>
